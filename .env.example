# Pooled Neon connection string for your application runtime.
# In Neon, copy the pooled connection string. The host usually includes "-pooler".
DATABASE_URL="your_neon_database_url_here"

# Direct Neon connection string for Prisma migrations.
# Use the non-pooled host for schema migrations.
DIRECT_URL="your_neon_direct_database_url_here"

# Auth.js / NextAuth secret. Generate a long random value for local development and production.
AUTH_SECRET="make_a_long_random_secret_here"

# Local development app URL.
NEXTAUTH_URL="http://localhost:3000"
