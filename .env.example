# Pooled Neon connection string for your application runtime.
# In Neon, copy the pooled connection string. The host usually includes "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB_NAME?sslmode=require&channel_binding=require"

# Direct Neon connection string for Prisma migrations.
# Use the non-pooled host for schema migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB_NAME?sslmode=require&channel_binding=require"
